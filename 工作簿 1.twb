        <view>
          <datasources>
            <datasource caption='shopping_trends' name='federated.0fiobuw1hweaz81ez2u8k0w0e9zf' />
          </datasources>
          <datasource-dependencies datasource='federated.0fiobuw1hweaz81ez2u8k0w0e9zf'>
            <column caption='频率编码' datatype='integer' name='[Calculation_935622869803892744]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Frequency of Purchases]&#13;&#10;    WHEN &apos;Bi-Weekly&apos; THEN 7&#13;&#10;    WHEN &apos;Weekly&apos; THEN 6&#13;&#10;    WHEN &apos;Fortnightly&apos; THEN 5&#13;&#10;    WHEN &apos;Monthly&apos; THEN 4&#13;&#10;    WHEN &apos;Every 3 Months&apos; THEN 3&#13;&#10;    WHEN &apos;Quarterly&apos; THEN 2&#13;&#10;    WHEN &apos;Annually&apos; THEN 1&#13;&#10;END' />
            </column>
            <column caption='品类平均' datatype='real' name='[Calculation_935622869804154889]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Category] : AVG([Purchase Amount (USD)]) }' />
            </column>
            <column caption='消费金额编码' datatype='integer' name='[Calculation_935622869804519434]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Purchase Amount (USD)] &lt; [Calculation_935622869804154889] * 0.8 THEN 1&#13;&#10;ELSEIF [Purchase Amount (USD)] &lt;= [Calculation_935622869804154889] * 1.2 THEN 2&#13;&#10;ELSE 3&#13;&#10;END' />
            </column>
            <column caption='折扣使用编码' datatype='integer' name='[Calculation_935622869804589067]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Discount Applied] = &apos;Yes&apos; THEN 0 ELSE 1 END' />
            </column>
            <column caption='订阅状态编码' datatype='integer' name='[Calculation_935622869804650508]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Subscription Status] = &apos;Yes&apos; THEN 1 ELSE 0 END' />
            </column>
            <column caption='x1_max' datatype='integer' name='[Calculation_935622869804961805]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX([Previous Purchases]) }' />
            </column>
            <column caption='x2_max' datatype='integer' name='[Calculation_935622869805363215]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED : MAX([Calculation_935622869803892744])}' />
            </column>
            <column caption='x3_max' datatype='integer' name='[Calculation_935622869805547537]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX([Calculation_935622869804519434]) }' />
            </column>
            <column caption='x4_max' datatype='integer' name='[Calculation_935622869805694995]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX([Calculation_935622869804589067]) }' />
            </column>
            <column caption='x5_max' datatype='real' name='[Calculation_935622869805805589]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX([Review Rating]) }' />
            </column>
            <column caption='x6_max' datatype='integer' name='[Calculation_935622869805912087]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX([Calculation_935622869804650508]) }' />
            </column>
            <column caption='X1' datatype='real' name='[Calculation_935622869808504857]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_935622869804961805] = [x1_max (复制)_935622869805207566] THEN 0&#13;&#10;ELSE ([Previous Purchases] - [x1_max (复制)_935622869805207566]) / ([Calculation_935622869804961805] - [x1_max (复制)_935622869805207566]) * 100&#13;&#10;END' />
            </column>
            <column caption='X2' datatype='real' name='[Calculation_935622869808549914]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_935622869805363215] = [x2_max (复制)_935622869805457424] THEN 0&#13;&#10;ELSE ([Calculation_935622869803892744] - [x2_max (复制)_935622869805457424]) / ([Calculation_935622869805363215] - [x2_max (复制)_935622869805457424]) * 100&#13;&#10;END' />
            </column>
            <column caption='X3' datatype='real' name='[Calculation_935622869808594971]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_935622869805547537] = [x3_max (复制)_935622869805600786] THEN 0&#13;&#10;ELSE ([Calculation_935622869804519434] - [x3_max (复制)_935622869805600786]) / ([Calculation_935622869805547537] - [x3_max (复制)_935622869805600786]) * 100&#13;&#10;END' />
            </column>
            <column caption='X4' datatype='real' name='[Calculation_935622869808635932]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_935622869805694995] = [x4_max (复制)_935622869805744148] THEN 0&#13;&#10;ELSE ([Calculation_935622869804589067] - [x4_max (复制)_935622869805744148]) / ([Calculation_935622869805694995] - [x4_max (复制)_935622869805744148]) * 100&#13;&#10;END' />
            </column>
            <column caption='X5' datatype='real' name='[Calculation_935622869808685085]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_935622869805805589] = [x5_max (复制)_935622869805850646] THEN 0&#13;&#10;ELSE ([Review Rating] - [x5_max (复制)_935622869805850646]) / ([Calculation_935622869805805589] - [x5_max (复制)_935622869805850646]) * 100&#13;&#10;END' />
            </column>
            <column caption='X6' datatype='real' name='[Calculation_935622869808721950]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_935622869805912087] = [x6_max (复制)_935622869805961240] THEN 0&#13;&#10;ELSE ([Calculation_935622869804650508] - [x6_max (复制)_935622869805961240]) / ([Calculation_935622869805912087] - [x6_max (复制)_935622869805961240]) * 100&#13;&#10;END' />
            </column>
            <column caption='忠诚度指数' datatype='real' name='[Calculation_935622869808762911]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_935622869808504857]*0.25 + [Calculation_935622869808549914]*0.2 + [Calculation_935622869808594971]*0.2 + [Calculation_935622869808635932]*0.05 + [Calculation_935622869808685085]*0.15 + [Calculation_935622869808721950]*0.15' />
            </column>
            <column caption='忠诚度等级' datatype='string' name='[Calculation_935622869808807968]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_935622869808762911] &lt; 20 THEN &apos;忠诚度极低&apos;&#13;&#10;ELSEIF [Calculation_935622869808762911] &lt; 40 THEN &apos;忠诚度低&apos;&#13;&#10;ELSEIF [Calculation_935622869808762911] &lt; 60 THEN &apos;忠诚度中等&apos;&#13;&#10;ELSEIF [Calculation_935622869808762911] &lt; 80 THEN &apos;忠诚度高&apos;&#13;&#10;ELSE &apos;忠诚度极高&apos;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Customer ID]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Discount Applied]' role='dimension' type='nominal' />
            <column datatype='string' name='[Frequency of Purchases]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Previous Purchases]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Purchase Amount (USD)]' role='measure' type='quantitative' />
            <column datatype='real' name='[Review Rating]' role='measure' type='quantitative' />
            <column datatype='string' name='[Subscription Status]' role='dimension' type='nominal' />
            <column-instance column='[Customer ID]' derivation='Count' name='[cnt:Customer ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_935622869808807968]' derivation='None' name='[none:Calculation_935622869808807968:nk]' pivot='key' type='nominal' />
            <column caption='x1_min' datatype='integer' name='[x1_max (复制)_935622869805207566]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MIN([Previous Purchases]) }' />
            </column>
            <column caption='x2_min' datatype='integer' name='[x2_max (复制)_935622869805457424]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED : MIN([Calculation_935622869803892744])}' />
            </column>
            <column caption='x3_min' datatype='integer' name='[x3_max (复制)_935622869805600786]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MIN([Calculation_935622869804519434]) }' />
            </column>
            <column caption='x4_min' datatype='integer' name='[x4_max (复制)_935622869805744148]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MIN([Calculation_935622869804589067]) }' />
            </column>
            <column caption='x5_min' datatype='real' name='[x5_max (复制)_935622869805850646]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MIN([Review Rating]) }' />
            </column>
            <column caption='x6_min' datatype='integer' name='[x6_max (复制)_935622869805961240]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MIN([Calculation_935622869804650508]) }' />
            </column>
          </datasource-dependencies>
          <manual-sort column='[federated.0fiobuw1hweaz81ez2u8k0w0e9zf].[none:Calculation_935622869808807968:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;忠诚度极低&quot;</bucket>
              <bucket>&quot;忠诚度低&quot;</bucket>
              <bucket>&quot;忠诚度中等&quot;</bucket>
